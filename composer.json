{
    "name": "sebastiandittrich/php-normalizer",
    "version": "0.2.2",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "SebastianDittrich\\Normalizer\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Sebastian Dittrich",
            "email": "sebastian@dittrich.dev"
        }
    ],
    "require": {
        "symfony/property-info": "^7.2",
        "phpdocumentor/reflection-docblock": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^4.3"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
